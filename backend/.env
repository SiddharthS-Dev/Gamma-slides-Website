# SlideVault Backend Configuration
# Copy this file to .env and adjust values

# Database
SLIDEVAULT_DATABASE_URL=postgresql+asyncpg://slidevault:slidevault@localhost:5432/slidevault

# Storage paths
SLIDEVAULT_PRESENTATIONS_DIR=D:\Gamma Slides\PPT
SLIDEVAULT_THUMBNAILS_DIR=D:\Gamma Slides\slidevault\storage\thumbnails
SLIDEVAULT_CACHE_DIR=D:\Gamma Slides\slidevault\storage\cache

# Ingestion
SLIDEVAULT_WATCH_INTERVAL_SECONDS=30
SLIDEVAULT_SUPPORTED_EXTENSIONS=.pptx,.pdf,.html

# Search
SLIDEVAULT_FUZZY_THRESHOLD=0.3

# Server
SLIDEVAULT_HOST=0.0.0.0
SLIDEVAULT_PORT=8000
SLIDEVAULT_DEBUG=true

# CORS
SLIDEVAULT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Provider (rule_based | openai | claude | gemini | ollama)
SLIDEVAULT_AI_PROVIDER=rule_based
SLIDEVAULT_AI_MODEL=
SLIDEVAULT_AI_API_KEY=
SLIDEVAULT_AI_BASE_URL=

# Classification
SLIDEVAULT_CLASSIFICATION_AUTO_ENABLED=true
SLIDEVAULT_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7
SLIDEVAULT_CLASSIFICATION_MAX_TAGS=20
SLIDEVAULT_CLASSIFICATION_MIN_TAGS=5

# Similarity
SLIDEVAULT_SIMILARITY_THRESHOLD=0.3
SLIDEVAULT_SIMILARITY_MAX_RESULTS=10
