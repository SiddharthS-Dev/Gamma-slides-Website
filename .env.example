# ── Required ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# Your domain (used by Caddy for auto-HTTPS)
DOMAIN=slides.yourcompany.com

# ── Optional overrides ────────────────────────────────────────────────────────
# SLIDEVAULT_AI_PROVIDER=rule_based   # rule_based | openai | claude | ollama
# SLIDEVAULT_AI_API_KEY=
# SLIDEVAULT_AI_MODEL=

# ── Dropbox Integration ───────────────────────────────────────────────────────
SLIDEVAULT_DROPBOX_APP_KEY=your_dropbox_app_key
SLIDEVAULT_DROPBOX_APP_SECRET=your_dropbox_app_secret
SLIDEVAULT_DROPBOX_REFRESH_TOKEN=your_dropbox_long_lived_refresh_token
SLIDEVAULT_DROPBOX_FOLDER_PATH=/Presentations
SLIDEVAULT_DROPBOX_SYNC_INTERVAL_SECONDS=300


